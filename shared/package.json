{
  "name": "@flyway-actions/shared",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    "./flyway-runner": "./src/flyway-runner.ts",
    "./resolve-path": "./src/resolve-path.ts",
    "./types": "./src/types.ts",
    "./test-utils": "./src/test-utils.ts",
    "./check-for-drift": "./src/check/check-for-drift.ts",
    "./check-for-code-review-violations": "./src/check/check-for-code-review-violations.ts",
    "./check-for-changes": "./src/check/check-for-changes.ts",
    "./pluralize": "./src/pluralize.ts"
  },
  "scripts": {
